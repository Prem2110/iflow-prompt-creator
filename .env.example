AICORE_CLIENT_ID=your-client-id
AICORE_CLIENT_SECRET=your-client-secret
AICORE_AUTH_URL=https://gen-ai.authentication.us10.hana.ondemand.com
AICORE_BASE_URL=https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com/v2
AICORE_RESOURCE_GROUP=default
LLM_DEPLOYMENT_ID=your-deployment-id

# LLM Usage Monitor (optional — omit LLM_USAGE_MONITOR_BASE_URL to disable)
LLM_USAGE_MONITOR_BASE_URL=https://llm-usage-monitor-egregious-armadillo-bt.cfapps.us10-001.hana.ondemand.com
LLM_USAGE_MONITOR_APP_ID=27
LLM_USAGE_MONITOR_MODEL_NAME=anthropic--claude-4.6-sonnet
LLM_USAGE_MONITOR_API_KEY=your-monitor-api-key
LLM_USAGE_MONITOR_CALL_TYPE_L_INVOKE=l_invoke
LLM_USAGE_MONITOR_CALL_TYPE_A_INVOKE=a_invoke

# Embedding model (for RAG chat)
EMBEDDING_DEPLOYMENT_ID=your-embedding-deployment-id
EMBEDDING_MODEL_NAME=text-embedding-3-large

# SAP Business Accelerator Hub API key (api.sap.com — free account)
# Omit or leave blank to disable Hub enrichment
SAP_HUB_API_KEY=your-sap-hub-api-key
